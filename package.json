{
  "name": "mithra-mcp",
  "version": "0.2.0",
  "description": "A local command center for a one-person, multi-project workspace: a GUI over every repo (project rail, embedded Claude terminal, boards, tasks) and the same workspace exposed as read-only MCP tools. One config file drives both.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "mithra-mcp": "index.js"
  },
  "scripts": {
    "start": "node ui/server.js",
    "dev": "node --watch ui/server.js",
    "mcp": "node index.js",
    "demo": "node demo/run-demo.mjs",
    "smoke": "node test-smoke.mjs",
    "test:protocol": "node test-protocol.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "agent",
    "command-center",
    "dashboard",
    "terminal",
    "xterm",
    "developer-tools",
    "local-first"
  ],
  "author": "Ruiciro Rivera (RuiciroRS)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RuiciroRS/mithra-mcp.git"
  },
  "homepage": "https://github.com/RuiciroRS/mithra-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "express": "^4.21.2",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18"
  }
}
