{
  "name": "mithra-mcp",
  "version": "0.2.0",
  "description": "MCP server that exposes a one-person, multi-project workspace (git state, Kanban boards, tasks, standup, deploy health) as read-only tools for any MCP client.",
  "type": "module",
  "main": "index.js",
  "bin": {
    "mithra-mcp": "index.js"
  },
  "scripts": {
    "start": "node index.js",
    "demo": "node demo/run-demo.mjs",
    "smoke": "node test-smoke.mjs",
    "test:protocol": "node test-protocol.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "agent",
    "command-center",
    "local-first"
  ],
  "author": "Ruiciro Rivera (RuiciroRS)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RuiciroRS/mithra-mcp.git"
  },
  "homepage": "https://github.com/RuiciroRS/mithra-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "engines": {
    "node": ">=18"
  }
}
